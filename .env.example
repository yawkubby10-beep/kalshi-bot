# ── Kalshi Bot v3 — Environment ──────────────────────────────────────────────
# Credentials
KALSHI_API_KEY=your_kalshi_api_key
KALSHI_PRIVATE_KEY=your_rsa_private_key_pem
# (or point to a mounted key file instead of pasting the PEM)
# KALSHI_PRIVATE_KEY_FILE=/path/to/kalshi_key.pem
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ALLOWED_USER_ID=your_numeric_telegram_id

# ── Mode ─────────────────────────────────────────────────────────────────────
# ALWAYS start paper. Paper mode now walks the real book and only fills makers
# when real trades print through your price — it predicts live behaviour.
PAPER_MODE=true
CRYPTOS=BTC,ETH,SOL
DB_PATH=kalshi_v3.db

# ── Sizing / risk ────────────────────────────────────────────────────────────
STAKE_MAX_CONTRACTS=10
MAX_STAKE_USD=9
MIN_FILL_CONTRACTS=2
DEPTH_FRACTION=0.30          # never take more than 30% of visible depth
MAX_CONCURRENT=3
PER_CRYPTO_MAX=1
MAX_DAILY_LOSS_USD=15        # halt new entries once daily P&L hits -this

# ── Model ────────────────────────────────────────────────────────────────────
TAIL_MULT=1.25              # widen the normal to respect crypto fat tails
SPIKE_MAX=2.5              # skip pricing when fast/slow vol ratio exceeds this
NEWS_BLACKOUT_UTC=12:25-12:45,13:55-14:15,18:00-18:20

# ── Convergence (the fill workhorse) ─────────────────────────────────────────
CONV_MIN_P=0.90            # hunt the liquid 88–96% zone (books empty above ~97%)
CONV_MIN_EV=0.02           # stiffer edge gate to compensate for lower p floor
CONV_MIN_TAU=45            # seconds-to-close lower bound
CONV_MAX_TAU=600           # upper bound (also traded on 1H in its last 10 min)
CONV_PRICE_MIN=72
CONV_PRICE_MAX=97
MAX_DIVERGENCE=0.12         # if model beats ask by more than this, assume WE are wrong
CONV_MAKER=true            # if ask too rich, post self-expiring post-only bid
MAKER_TTL_S=45             # resting order lifetime (server-side expiration)

# ── Lag (opportunist) ────────────────────────────────────────────────────────
LAG_ENABLED=true
LAG_Z=3.0                  # vol-normalized burst threshold
LAG_LOOKBACK_S=8
LAG_MIN_MOVE=0.0008
LAG_MIN_EV=0.04            # only take if book lags fair by ≥4¢ net of fees
LAG_MIN_TAU=90
LAG_MAX_TAU=900
LAG_COOLDOWN_S=60

# ── Exits ────────────────────────────────────────────────────────────────────
STOP_P=0.30                # cut a position if model prob falls below this
STOP_MIN_TAU=35            # ...but not in the final 35s (let it settle)

# ── Fee overrides (defaults match Kalshi's published schedule) ──────────────
# FEE_TAKER_MULT=0.07
# FEE_MAKER_MULT=0.0175
